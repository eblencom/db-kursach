# SQL Server (для подключения к реальной БД)
# Если не заданы - используется mock-данные без SQL Server
DB_SERVER=localhost
DB_USER=sa
DB_PASSWORD=YourPassword123
DB_NAME=FinancialNewsDB
DB_ENCRYPT=false

# Принудительно использовать mock-данные (без SQL Server)
# USE_MOCK_DATA=true

# NextAuth (обязательно для входа/регистрации)
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000
